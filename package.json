{
  "name": "ministats",
  "version": "1.0.0",
  "description": "Real-time system metrics dashboard",
  "module": "src/index.ts",
  "bin": {
    "ministats": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target=bun --minify && chmod +x dist/index.js",
    "dev": "bun run src/index.ts",
    "start": "bun run dist/ministats.js"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0"
  }
}
